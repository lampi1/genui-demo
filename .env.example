# Google AI Studio key (free tier) — https://aistudio.google.com/apikey
# Copy to .env.local (gitignored) and fill in.
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional: OpenAI key with prepaid credit. When set it becomes the PRIMARY
# provider (cheapest model, ~€0.001/message); Gemini/Groq stay as fallbacks.
# OPENAI_API_KEY=
# GENUI_OPENAI_MODEL=gpt-5-nano

# Optional: override the model (default gemini-flash-lite-latest — the stable
# free-tier choice as of 2026-07; 3.5-flash was capacity-limited, 2.5 retired).
# GENUI_MODEL=gemini-flash-lite-latest

# Optional but recommended: Groq key (free, no card — https://console.groq.com/keys).
# When set, rate-limited requests silently fall back to Groq's free tier
# (~30 req/min + up to 14.4k req/day on top of Gemini's).
# GROQ_API_KEY=
# GENUI_FALLBACK_MODEL=llama-3.3-70b-versatile
